# =============================================================================
# Engramia — TEST Environment Template
# =============================================================================
# Copy to .env.test on the production server.
# Test environment uses mock LLM — no real API keys needed for most tests.
# DB credentials are hardcoded (non-secret, ephemeral DB on tmpfs).
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Core — Storage & Database
# -----------------------------------------------------------------------------
ENGRAMIA_STORAGE=postgres
ENGRAMIA_DATABASE_URL=postgresql://engramia_test:test_password_local_only@pgvector-test:5432/engramia_test
ENGRAMIA_DATA_PATH=/data/engramia_test_data

# -----------------------------------------------------------------------------
# 2. LLM Provider — Mock server
# -----------------------------------------------------------------------------
ENGRAMIA_LLM_PROVIDER=openai
ENGRAMIA_LLM_MODEL=gpt-4.1-mini
ENGRAMIA_LLM_TIMEOUT=10.0
ENGRAMIA_LLM_CONCURRENCY=5

# Point to mock LLM container (overrides OpenAI base URL)
OPENAI_BASE_URL=http://mock-llm:8000/v1
OPENAI_API_KEY=test-key-not-real

# -----------------------------------------------------------------------------
# 3. Embeddings (mock)
# -----------------------------------------------------------------------------
ENGRAMIA_EMBEDDING_MODEL=text-embedding-3-small
# ENGRAMIA_LOCAL_EMBEDDINGS=true  # Uncomment for fully offline tests

# -----------------------------------------------------------------------------
# 4. Authentication
# -----------------------------------------------------------------------------
ENGRAMIA_AUTH_MODE=db
ENGRAMIA_BOOTSTRAP_TOKEN=test-bootstrap-token-for-ci-only-32chars
ENGRAMIA_ENVIRONMENT=test
ENGRAMIA_ALLOW_NO_AUTH=false

# -----------------------------------------------------------------------------
# 5. Security (relaxed for testing)
# -----------------------------------------------------------------------------
ENGRAMIA_CORS_ORIGINS=http://localhost:8200
ENGRAMIA_RATE_LIMIT_DEFAULT=1000
ENGRAMIA_RATE_LIMIT_EXPENSIVE=100
ENGRAMIA_RATE_LIMIT_PER_KEY=10000
ENGRAMIA_MAX_BODY_SIZE=10485760
ENGRAMIA_REDACTION=false

# -----------------------------------------------------------------------------
# 6. Billing (disabled in test)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy

# -----------------------------------------------------------------------------
# 7. Observability
# -----------------------------------------------------------------------------
ENGRAMIA_JSON_LOGS=false
ENGRAMIA_METRICS=false
ENGRAMIA_METRICS_TOKEN=test-token

# -----------------------------------------------------------------------------
# 8. Background Jobs
# -----------------------------------------------------------------------------
ENGRAMIA_JOB_POLL_INTERVAL=0.5
ENGRAMIA_JOB_MAX_CONCURRENT=2

# -----------------------------------------------------------------------------
# 9. Docker Compose
# -----------------------------------------------------------------------------
IMAGE_TAG=test                                         # Built locally or from CI
