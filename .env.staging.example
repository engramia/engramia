# =============================================================================
# Engramia — STAGING Environment Template
# =============================================================================
# Copy to .env.staging on the production server and fill in all required values.
# Staging mirrors production config — use test API keys, test Stripe mode.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Core — Storage & Database
# -----------------------------------------------------------------------------
ENGRAMIA_STORAGE=postgres
ENGRAMIA_DATABASE_URL=postgresql://engramia_staging:CHANGE_ME@pgvector-staging:5432/engramia_staging
STAGING_POSTGRES_PASSWORD=CHANGE_ME                   # [REQUIRED] Used by pgvector-staging container
ENGRAMIA_DATA_PATH=/data/engramia_staging_data

# -----------------------------------------------------------------------------
# 2. LLM Provider
# -----------------------------------------------------------------------------
ENGRAMIA_LLM_PROVIDER=openai
ENGRAMIA_LLM_MODEL=gpt-4.1-mini                       # Cheaper model for staging
ENGRAMIA_LLM_TIMEOUT=30.0
ENGRAMIA_LLM_CONCURRENCY=5
ENGRAMIA_MAX_LLM_RESPONSE=20000

OPENAI_API_KEY=sk-...                                  # [REQUIRED] Can share prod key or use separate

# -----------------------------------------------------------------------------
# 3. Embeddings
# -----------------------------------------------------------------------------
ENGRAMIA_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# 4. Authentication
# -----------------------------------------------------------------------------
ENGRAMIA_AUTH_MODE=db
ENGRAMIA_BOOTSTRAP_TOKEN=CHANGE_ME_STAGING_MIN_32_CHARS
ENGRAMIA_ENVIRONMENT=staging

# -----------------------------------------------------------------------------
# 5. Security
# -----------------------------------------------------------------------------
ENGRAMIA_CORS_ORIGINS=https://staging-app.engramia.dev
ENGRAMIA_RATE_LIMIT_DEFAULT=60
ENGRAMIA_RATE_LIMIT_EXPENSIVE=10
ENGRAMIA_RATE_LIMIT_PER_KEY=120
ENGRAMIA_MAX_BODY_SIZE=1048576
ENGRAMIA_REDACTION=true

# -----------------------------------------------------------------------------
# 6. Billing (Stripe test mode)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...                          # [REQUIRED] Stripe TEST key
STRIPE_WEBHOOK_SECRET=whsec_...                        # [REQUIRED] Stripe TEST webhook secret

# -----------------------------------------------------------------------------
# 7. Observability
# -----------------------------------------------------------------------------
ENGRAMIA_JSON_LOGS=true
ENGRAMIA_METRICS=true
ENGRAMIA_METRICS_TOKEN=CHANGE_ME_STAGING

# -----------------------------------------------------------------------------
# 8. Background Jobs
# -----------------------------------------------------------------------------
ENGRAMIA_JOB_POLL_INTERVAL=2.0
ENGRAMIA_JOB_MAX_CONCURRENT=3

# -----------------------------------------------------------------------------
# 9. GDPR / Governance
# -----------------------------------------------------------------------------
ENGRAMIA_DSR_SLA_DAYS=30

# -----------------------------------------------------------------------------
# 10. Docker Compose
# -----------------------------------------------------------------------------
IMAGE_TAG=v0.6.5                                       # [REQUIRED] Image tag to deploy

# -----------------------------------------------------------------------------
# 11. Dashboard (Next.js)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=https://staging-app.engramia.dev
NEXTAUTH_SECRET=CHANGE_ME_STAGING
STAGING_API_URL=https://staging-api.engramia.dev
STAGING_DASHBOARD_URL=https://staging-app.engramia.dev
