# Engramia — VM environment template
# Copy to .env and fill in your values before running docker compose.

# =============================================================================
# Storage backend
# =============================================================================
# json  — single-machine, file-based (default, no extra deps)
# postgres — PostgreSQL + pgvector (recommended for production)
ENGRAMIA_STORAGE=json
ENGRAMIA_DATA_PATH=/data/engramia_data

# Uncomment for PostgreSQL backend:
# ENGRAMIA_STORAGE=postgres
# ENGRAMIA_DATABASE_URL=postgresql://engramia:CHANGE_ME@pgvector:5432/engramia

# =============================================================================
# LLM provider
# =============================================================================
ENGRAMIA_LLM_PROVIDER=openai
ENGRAMIA_LLM_MODEL=gpt-4.1

OPENAI_API_KEY=sk-...

# Anthropic alternative:
# ENGRAMIA_LLM_PROVIDER=anthropic
# ENGRAMIA_LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Embeddings
# =============================================================================
ENGRAMIA_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Authentication — REQUIRED in production
# Comma-separated list of Bearer tokens.
# IMPORTANT: Empty keys alone do NOT disable auth — the API returns 503.
# To run without auth (dev only) you must ALSO set ENGRAMIA_ALLOW_NO_AUTH=true.
# =============================================================================
ENGRAMIA_API_KEYS=change-me-before-deployment
# ENGRAMIA_ALLOW_NO_AUTH=true  # Uncomment only for local dev — never in production

# =============================================================================
# Security
# =============================================================================
# Allowed CORS origins, comma-separated. Empty = CORS disabled.
ENGRAMIA_CORS_ORIGINS=

# Rate limiting (requests per minute per IP)
ENGRAMIA_RATE_LIMIT_DEFAULT=60
ENGRAMIA_RATE_LIMIT_EXPENSIVE=10

# Max request body size in bytes (default 1 MB)
ENGRAMIA_MAX_BODY_SIZE=1048576

# =============================================================================
# GHCR image (set by docker-compose.prod.yml)
# =============================================================================
IMAGE_TAG=latest
