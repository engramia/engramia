# =============================================================================
# Engramia — PRODUCTION Environment Template
# =============================================================================
# Copy to .env on the production server and fill in all required values.
# Lines marked [REQUIRED] must be set before starting. Others have safe defaults.
#
# See also: docs/environment-variables.md for full documentation.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Core — Storage & Database
# -----------------------------------------------------------------------------
ENGRAMIA_STORAGE=postgres                                                      # [REQUIRED] Must be postgres for production
ENGRAMIA_DATABASE_URL=postgresql://engramia:CHANGE_ME@pgvector:5432/engramia   # [REQUIRED] PostgreSQL connection string
POSTGRES_PASSWORD=CHANGE_ME                                                    # [REQUIRED] Used by pgvector Docker container
ENGRAMIA_DATA_PATH=/data/engramia_data                                         # Fallback path for JSON storage (unused with postgres)

# -----------------------------------------------------------------------------
# 2. LLM Provider
# -----------------------------------------------------------------------------
ENGRAMIA_LLM_PROVIDER=openai        # openai | anthropic
ENGRAMIA_LLM_MODEL=gpt-4.1          # Model for eval/compose/evolve
ENGRAMIA_LLM_TIMEOUT=30.0           # Per-request timeout in seconds
ENGRAMIA_LLM_CONCURRENCY=10         # Max concurrent LLM calls (bounded semaphore)
ENGRAMIA_MAX_LLM_RESPONSE=20000     # Max LLM response length in chars (truncated above)

OPENAI_API_KEY=sk-...                # [REQUIRED if openai] OpenAI API key
# ANTHROPIC_API_KEY=sk-ant-...       # [REQUIRED if anthropic] Anthropic API key

# -----------------------------------------------------------------------------
# 3. Embeddings
# -----------------------------------------------------------------------------
ENGRAMIA_EMBEDDING_MODEL=text-embedding-3-small   # OpenAI embedding model
# ENGRAMIA_LOCAL_EMBEDDINGS=true                   # Use sentence-transformers (384-dim, no API key)

# -----------------------------------------------------------------------------
# 4. Authentication — REQUIRED
# -----------------------------------------------------------------------------
ENGRAMIA_AUTH_MODE=db                              # [REQUIRED] Must be 'db' for production
ENGRAMIA_BOOTSTRAP_TOKEN=CHANGE_ME_MIN_32_CHARS    # [REQUIRED] One-time token for creating first API key (min 32 chars)
ENGRAMIA_ENVIRONMENT=production                    # [REQUIRED] Guards against dev mode in production
# ENGRAMIA_ALLOW_NO_AUTH=false                     # NEVER set to true in production
# ENGRAMIA_API_KEYS=                               # Only for auth_mode=env (legacy)
# ENGRAMIA_ENV_AUTH_ROLE=owner                     # Default role for env-based auth

# -----------------------------------------------------------------------------
# 5. OIDC / SSO (Enterprise)
# -----------------------------------------------------------------------------
# ENGRAMIA_OIDC_ISSUER=https://your-idp.example.com
# ENGRAMIA_OIDC_AUDIENCE=engramia
# ENGRAMIA_OIDC_ROLE_CLAIM=engramia_role           # JWT claim for role mapping
# ENGRAMIA_OIDC_DEFAULT_ROLE=reader                 # Role when claim is absent
# ENGRAMIA_OIDC_TENANT_CLAIM=                       # JWT claim for tenant_id
# ENGRAMIA_OIDC_PROJECT_CLAIM=                      # JWT claim for project_id

# -----------------------------------------------------------------------------
# 6. Cloud Auth (Dashboard SSO)
# -----------------------------------------------------------------------------
# RS256 signing (recommended — H-02 fix). Generate with: engramia auth generate-keys
# ENGRAMIA_JWT_PRIVATE_KEY=/secrets/private_key.pem  # RSA private key path (or PEM string)
# ENGRAMIA_JWT_PUBLIC_KEY=/secrets/public_key.pem    # RSA public key path (or PEM string)
# HS256 fallback (deprecated — leaked secret = full auth bypass for all tenants):
# ENGRAMIA_JWT_SECRET=                              # JWT secret for cloud auth (dashboard ↔ API)

# -----------------------------------------------------------------------------
# 7. Security
# -----------------------------------------------------------------------------
ENGRAMIA_CORS_ORIGINS=                              # Comma-separated allowed origins (empty = CORS disabled)
ENGRAMIA_RATE_LIMIT_DEFAULT=60                      # Requests/min per IP (standard endpoints)
ENGRAMIA_RATE_LIMIT_EXPENSIVE=10                    # Requests/min per IP (evaluate, compose, evolve)
ENGRAMIA_RATE_LIMIT_PER_KEY=120                     # Requests/min per API key (all paths)
ENGRAMIA_MAX_BODY_SIZE=1048576                      # Max request body (1 MB)
ENGRAMIA_REDACTION=true                             # PII redaction pipeline (emails, IPs, tokens)

# -----------------------------------------------------------------------------
# 8. Billing (Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...                       # [REQUIRED for billing] Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_...                     # [REQUIRED for billing] Stripe webhook signing secret

# -----------------------------------------------------------------------------
# 9. Observability
# -----------------------------------------------------------------------------
ENGRAMIA_JSON_LOGS=true                             # [REQUIRED] Structured JSON logs for Loki/Promtail
ENGRAMIA_METRICS=true                               # [REQUIRED] Enable /metrics Prometheus endpoint
ENGRAMIA_METRICS_TOKEN=CHANGE_ME                    # [REQUIRED] Bearer token protecting /metrics endpoint

# OpenTelemetry (optional)
ENGRAMIA_TELEMETRY=false                            # Enable OTLP tracing
ENGRAMIA_OTEL_ENDPOINT=http://localhost:4317        # OTLP gRPC collector
ENGRAMIA_OTEL_SERVICE_NAME=engramia-api             # Service name in traces

# -----------------------------------------------------------------------------
# 10. Background Jobs
# -----------------------------------------------------------------------------
ENGRAMIA_JOB_POLL_INTERVAL=2.0                     # Worker poll interval (seconds)
ENGRAMIA_JOB_MAX_CONCURRENT=3                      # Max concurrent job executions

# Maintenance mode (set to 1/true/yes to enable — returns 503 on all endpoints)
# ENGRAMIA_MAINTENANCE=false

# -----------------------------------------------------------------------------
# 11. GDPR / Governance
# -----------------------------------------------------------------------------
ENGRAMIA_DSR_SLA_DAYS=30                           # Data Subject Request SLA (days, GDPR Art. 12 §3)

# -----------------------------------------------------------------------------
# 12. SDK / Bridge (only if using EngramiaBridge SDK client)
# -----------------------------------------------------------------------------
# ENGRAMIA_API_URL=https://api.engramia.dev
# ENGRAMIA_API_KEY=eng_...

# -----------------------------------------------------------------------------
# 13. Build metadata (set by CI/CD — do not set manually)
# -----------------------------------------------------------------------------
# GIT_COMMIT=                                      # Injected by Docker build
# BUILD_TIME=                                      # Injected by Docker build

# -----------------------------------------------------------------------------
# 14. Docker Compose
# -----------------------------------------------------------------------------
IMAGE_TAG=v0.6.5                                   # [REQUIRED] GHCR image tag (e.g. v0.6.5)

# -----------------------------------------------------------------------------
# 15. Dashboard (Next.js)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=https://app.engramia.dev              # Dashboard URL
NEXTAUTH_SECRET=CHANGE_ME                          # [REQUIRED] NextAuth.js signing secret
NEXT_PUBLIC_API_URL=https://api.engramia.dev       # Backend API URL
# GOOGLE_CLIENT_ID=                                 # Google OAuth (optional)
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=                                 # GitHub OAuth (optional)
# GITHUB_CLIENT_SECRET=
# NEXT_PUBLIC_STRIPE_PRO_URL=                       # Stripe checkout links (set in Stripe Dashboard)
# NEXT_PUBLIC_STRIPE_TEAM_URL=

# -----------------------------------------------------------------------------
# 16. Monitoring Stack (docker-compose.monitoring.yml)
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=CHANGE_ME                    # [REQUIRED] Grafana admin password
# GRAFANA_ROOT_URL=http://localhost:3000
# SMTP_HOST=                                        # SMTP for Grafana alerts
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=monitoring@engramia.dev
