<?xml version="1.0" encoding="UTF-16"?>
<!--
  Windows Task Scheduler definition for Engramia CI watchdog.

  Import with:
    schtasks /Create /XML scripts\ci-check-task.xml /TN "Engramia\CI-Check"

  Or via GUI: Task Scheduler → Action → Import Task → select this file.

  IMPORTANT: Edit the <Command> and <WorkingDirectory> paths below
  to match where your Git Bash / agent-brain repo actually lives.
-->
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Hourly CI watchdog: checks engramia/engramia GitHub Actions CI on main. If red, Claude Code fixes the code, pushes, and retries up to 5 times until CI is green.</Description>
    <Author>Marek</Author>
  </RegistrationInfo>

  <Triggers>
    <!-- Run every hour, indefinitely -->
    <TimeTrigger>
      <Repetition>
        <Interval>PT1H</Interval>
        <StopAtDurationEnd>false</StopAtDurationEnd>
      </Repetition>
      <!-- Start time: adjust to any near-future timestamp -->
      <StartBoundary>2026-04-09T07:00:00</StartBoundary>
      <Enabled>true</Enabled>
    </TimeTrigger>
  </Triggers>

  <Principals>
    <Principal id="Author">
      <!-- Run as logged-in user so gh CLI uses your stored credentials -->
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>

  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT2H</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>

  <Actions Context="Author">
    <Exec>
      <Command>powershell.exe</Command>
      <Arguments>-NonInteractive -ExecutionPolicy Bypass -File "C:\Users\soulf\agent-brain\scripts\ci-check.ps1" -AutoRepair -Quiet</Arguments>
      <WorkingDirectory>C:\Users\soulf\agent-brain</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
