# Caddyfile.staging
# Staging reverse proxy — runs inside caddy-staging container.
# External access via Caddy on prod server (see main Caddyfile for TLS termination).
#
# Staging subdomains (add to main Caddyfile on prod server):
#   staging-api.engramia.dev   → localhost:8100
#   staging-app.engramia.dev   → localhost:3100

:80 {
    handle /api/* {
        reverse_proxy engramia-api-staging:8000
    }

    handle {
        reverse_proxy dashboard-staging:3000
    }
}
